# ============================================
# Cloud Native Demo — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e ajuste os valores

# Backend
PORT=3001
SESSION_SECRET=troque-por-uma-chave-aleatoria-segura

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=cloudnative
KEYCLOAK_CLIENT_ID=demo-app
KEYCLOAK_CLIENT_SECRET=demo-secret-123

# URLs
REDIRECT_URI=http://localhost:3001/auth/callback
FRONTEND_URL=http://localhost:5173

# Frontend (Vite)
VITE_API_URL=http://localhost:3001
